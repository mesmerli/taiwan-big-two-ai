{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "taiwan-big-two-ai",
  "version": "1.5.8",
  "identifier": "com.mesmerli.taiwanbig2ai",
  "build": {
    "frontendDist": "../www"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Taiwan Big Two AI",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

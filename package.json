{
  "name": "taiwan-big-two-ai",
  "version": "1.5.13",
  "description": "Modern Big Two game with LLM-powered AI integration",
  "license": "AGPL-3.0-only",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "npm run increment-build && electron-builder --dir",
    "dist": "npm run increment-build && electron-builder",
    "dist:store": "cross-env BUILD_TARGET=STORE npm run dist",
    "dist:github": "cross-env BUILD_TARGET=GITHUB npm run dist",
    "dist:msix": "npm run increment-build && electron-builder --win appx",
    "package": "npm run increment-build && electron-packager . \"Taiwan Big Two AI\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "increment-build": "node scripts/increment-build.js",
    "test": "node tests/logic.test.js && node tests/ui.test.js",
    "test:ui": "node tests/ui.test.js",
    "build-StoreBridge": "node-gyp clean configure build --directory=StoreBridge"
  },
  "build": {
    "appId": "mesmerli.TaiwanBig2AI",
    "buildVersion": "1.5.13.0",
    "buildNumber": "13",
    "productName": "Taiwan Big Two AI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "appx"
      ],
      "icon": "src/assets/logo.png",
      "artifactName": "Taiwan Big Two AI_1.5.13.0.${ext}"
    },
    "appx": {
      "identityName": "mesmerli.TaiwanBig2AI",
      "publisher": "CN=B50F36C9-7E5E-4652-A715-0185D35ADE64",
      "publisherDisplayName": "mesmerli",
      "applicationId": "mesmerli.TaiwanBig2AI",
      "languages": [
        "en-US",
        "zh-TW"
      ]
    },
    "files": [
      "**/*",
      "!dist/*",
      "!src-tauri/*",
      "!android/*",
      "!www/*",
      "!release/*",
      "!palmOS/*",
      "!screenshots/*",
      "!Documents/*",
      "!tests/*",
      "!scripts/*",
      "!.winapp/*",
      "!StoreBridge/build/Release/*.pdb",
      "!StoreBridge/build/Release/*.lib",
      "!StoreBridge/build/Release/*.exp",
      "!StoreBridge/build/StoreBridge.*",
      "!StoreBridge/build/obj/*"
    ]
  },
  "keywords": [
    "bigtwo",
    "poker",
    "electron",
    "ai"
  ],
  "author": "mesmerli",
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@microsoft/winappcli": "latest",
    "@tauri-apps/cli": "^2.11.2",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "nan": "^2.27.0",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4"
  },
  "buildTarget": "STORE"
}